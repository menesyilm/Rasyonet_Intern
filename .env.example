# Copy this file to .env and fill in local values.
# .env is ignored by git and must not be committed.

# Shared application settings
SQL_DATABASE=Rasyonet_Intern
SQL_USER=sa
MONGODB_DATABASE=Rasyonet_Intern
VITE_API_BASE_URL=http://localhost:5010/api
VITE_SIGNALR_URL=http://localhost:5010/hubs/dashboard

# Full Docker Compose environment: docker compose up --build
DOCKER_SQL_HOST=mssql,1433
MSSQL_SA_PASSWORD=change-this-password
MSSQL_PID=Developer
DOCKER_MONGODB_CONNECTION_STRING=mongodb://mongodb:27017/?replicaSet=rs0

# Local DB environment: docker compose -f docker-compose.local-db.yml up --build
# Use SQL Authentication because Windows Authentication from a Linux container will not work.
LOCAL_SQL_CONNECTION_STRING=Server=host.docker.internal,1433;Database=Rasyonet_Intern;User Id=YOUR_SQL_USER;Password=YOUR_SQL_PASSWORD;TrustServerCertificate=True;Encrypt=False;
LOCAL_MONGODB_CONNECTION_STRING=mongodb://host.docker.internal:27017/?replicaSet=rs0&directConnection=true
